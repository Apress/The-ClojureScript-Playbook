(ns myapp.e04
  (:require [reagent.core :as r]
            [reagent.dom.client :as rdom]))

(defonce state (r/atom {:audio-context nil
                        :analyser nil
                        :data-array nil
                        :animation-frame nil}))

(defn get-audio-context []
      (or (:audio-context @state)
          (let [ctx (js/AudioContext.)]
               (swap! state assoc :audio-context ctx)
               ctx)))

(defn draw-frequency-loop! []
  (let [canvas (.getElementById js/document "waveform")
        ctx (.getContext canvas "2d")]
    (when-let [analyser (:analyser @state)]
      (let [data-array (:data-array @state)]
        (letfn [(draw []
                  (swap! state assoc :animation-frame (js/requestAnimationFrame draw))

                  ;; get frequency data
                  (.getByteFrequencyData analyser data-array)

                  ;; clear background fully each frame
                  (let [w (.-width canvas)
                        h (.-height canvas)
                        center-x (/ w 2)
                        center-y (/ h 2)
                        max-radius (min (/ w 2) (/ h 2))]
                    (set! (.-fillStyle ctx) "#000")
                    (.fillRect ctx 0 0 w h)

                    ;; draw radial bars
                    (set! (.-lineWidth ctx) 2)
                    (let [num-bars (.-length data-array)
                          angle-step (/ (* 2 Math/PI) num-bars)]
                      (.beginPath ctx)
                      (loop [i 0]
                        (when (< i num-bars)
                          (let [v (aget data-array i)
                                norm (/ v 255.0)
                                ;bar-length (+ 20 (* norm max-radius))
                                bar-length (* 2 (+ 50 (* norm max-radius)))
                                angle (* i angle-step)

                                x-end (+ center-x (* bar-length (Math/cos angle)))
                                y-end (+ center-y (* bar-length (Math/sin angle)))

                                ;; amplitude-controlled color
                                hue (mod (+ (* 360 (/ i num-bars)) 120) 360)
                                lightness (+ 20 (* 50 norm))] ;; from 20% (dark) to 70% (bright)

                            (set! (.-strokeStyle ctx) (str "hsl(" hue ", 100%, " lightness "%)"))
                            (.beginPath ctx)
                            (.moveTo ctx center-x center-y)
                            (.lineTo ctx x-end y-end)
                            (.stroke ctx))

                          (recur (inc i)))))))]
(draw))))))

(defn draw-loop! []
      (let [canvas (.getElementById js/document "waveform")
            ctx (.getContext canvas "2d")
            analyser (:analyser @state)
            data-array (:data-array @state)
            w (.-width canvas)
            h (.-height canvas)]
           (when analyser
                 (letfn [(draw []
                               (swap! state assoc :animation-frame (js/requestAnimationFrame draw))
                               (.getByteTimeDomainData analyser data-array)
                               (set! (.-fillStyle ctx) "#111")
                               (.fillRect ctx 0 0 w h)
                               (set! (.-lineWidth ctx) 2)
                               (set! (.-strokeStyle ctx) "#00FFAA")
                               (.beginPath ctx)
                               (let [slice (/ w (.-length data-array))]
                                    (loop [i 0
                                           x 0]
                                          (when (< i (.-length data-array))
                                                (let [v (/ (aget data-array i) 128.0)
                                                      y (* v (/ h 2))]
                                                     (if (zero? i)
                                                       (.moveTo ctx x y)
                                                       (.lineTo ctx x y))
                                                     (recur (inc i) (+ x slice))))))
                               (.lineTo ctx w (/ h 2))
                               (.stroke ctx))]
(draw)))))

(defn start-recording! []
  (when (not (:started? @state))
    (swap! state assoc :started? true)
    (-> (js/navigator.mediaDevices.getUserMedia #js {:audio true})
        (.then (fn [stream]
                 (let [ctx (get-audio-context)
                       source (.createMediaStreamSource ctx stream)
                       analyser (.createAnalyser ctx)]
                   (set! (.-fftSize analyser) 2048)
                   (.connect source analyser ctx.destination)
                   (let [data-array (js/Uint8Array. (.-frequencyBinCount analyser))]
                     (swap! state assoc
                            :analyser analyser
                            :data-array data-array)
                     (draw-frequency-loop!))))))))

(defn resize-canvas! []
  (let [canvas (.getElementById js/document "waveform")]
    (set! (.-width canvas) (.-innerWidth js/window))
    (set! (.-height canvas) (.-innerHeight js/window))))

(defn ^:export init []
  (resize-canvas!)
  (.addEventListener js/window "resize" resize-canvas!)
  (.addEventListener js/document "click" (fn [_] (start-recording!))))

